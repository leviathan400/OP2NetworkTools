// Windows resource script (configured by CMake -> app.rc with an absolute icon path).
// Icon "1" is the lowest-id icon, which Explorer / the taskbar use for the executable.
// "GLFW_ICON" is the name GLFW looks up to set the window's title-bar / taskbar icon.
1         ICON "@OP2_APP_ICON@"
GLFW_ICON ICON "@OP2_APP_ICON@"

// Version info shown on the exe's Details tab (Product name, Company, Copyright, ...).
1 VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Outpost Universe"
            VALUE "FileDescription",  "OP2DummyPlayer - external Outpost 2 multiplayer client"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "OP2DummyPlayer"
            VALUE "LegalCopyright",   "Copyright (C) Outpost Universe"
            VALUE "OriginalFilename", "OP2DummyPlayer.exe"
            VALUE "ProductName",      "OP2DummyPlayer"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
